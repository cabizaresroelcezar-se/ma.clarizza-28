---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Happy 28th Birthday, Ma. Clarizza Folloso! A personal gift from your love, celebrating 10 years together. 🎉" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&family=Reenie+Beanie&family=Dancing+Script:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" />
  </head>
  <body>
    <!-- Chapter navigation dots (desktop only) -->
    <nav class="chapter-nav" id="chapterNav" aria-label="Sections">
      <a href="#hero"    class="chapter-dot active" data-section="hero"    title="Home"></a>
      <a href="#bento"   class="chapter-dot"         data-section="bento"   title="About"></a>
      <a href="#message" class="chapter-dot"         data-section="message" title="Letter"></a>
      <a href="#gallery" class="chapter-dot"         data-section="gallery" title="Gallery"></a>
      <a href="#wishes"  class="chapter-dot"         data-section="wishes"  title="Wishes"></a>
    </nav>

    <slot />

    <!-- Floating music player -->
    <div id="music-player">
      <!-- Collapsed toggle button -->
      <button id="music-toggle" aria-label="Play our song">
        <span id="music-icon">🎵</span>
        <span id="music-label">our song</span>
      </button>
      <!-- Expanded embed panel -->
      <div id="music-panel" aria-hidden="true">
        <div id="music-panel-header">
          <span>our song 🎵</span>
          <button id="music-close" aria-label="Close player">✕</button>
        </div>
        <div id="yt-slot"></div>
      </div>
    </div>

    <style>
      #music-player {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 500;
        display: flex;
        flex-direction: column-reverse; /* panel above toggle on desktop */
        align-items: flex-end;
        gap: 8px;
      }
      #music-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--pink-hot);
        color: white;
        border: none;
        border-radius: 999px;
        padding: 10px 18px 10px 14px;
        font-family: 'Reenie Beanie', cursive;
        font-size: 1.15rem;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(233, 30, 140, 0.35);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        animation: pulse-soft 2.5s ease-in-out infinite;
      }
      #music-toggle:hover {
        transform: scale(1.06);
        box-shadow: 0 6px 28px rgba(233, 30, 140, 0.5);
        animation: none;
      }
      #music-icon { font-size: 1.1rem; }

      #music-panel {
        background: white;
        border: 1.5px solid #f8bbd0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 12px 48px rgba(233, 30, 140, 0.18), 0 4px 16px rgba(0,0,0,0.08);
        width: 300px;
        max-height: 0;
        opacity: 0;
        pointer-events: none;
        transition: max-height 0.45s cubic-bezier(0.22,1,0.36,1), opacity 0.3s ease;
      }
      #music-panel.open {
        max-height: 240px;
        opacity: 1;
        pointer-events: all;
      }
      #music-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px 8px;
        font-family: 'Reenie Beanie', cursive;
        font-size: 1.15rem;
        color: var(--pink-hot);
        border-bottom: 1px solid #fce4ec;
      }
      #music-close {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-muted);
        font-size: 0.85rem;
        line-height: 1;
        padding: 2px 6px;
        border-radius: 50%;
        transition: background 0.2s;
      }
      #music-close:hover { background: #fce4ec; }
      #yt-slot iframe {
        display: block;
        width: 100%;
        height: 168px;
        border: none;
      }

      @keyframes pulse-soft {
        0%, 100% { box-shadow: 0 4px 20px rgba(233,30,140,0.35); }
        50%       { box-shadow: 0 4px 32px rgba(233,30,140,0.6); }
      }
      @media (max-width: 640px) {
        /* On mobile, move player to top-right and open panel below the toggle */
        #music-player {
          top: 16px;
          right: 12px;
          bottom: auto;
          flex-direction: column; /* panel below toggle on mobile */
          align-items: flex-end;
          gap: 6px;
        }
        #music-panel {
          width: calc(100vw - 40px);
          max-width: 360px;
        }
        #music-toggle { padding: 8px 12px 8px 10px; font-size: 1rem; }
        #yt-slot iframe { height: 180px; }
      }
    </style>

    <script>
      const toggle  = document.getElementById('music-toggle')!;
      const panel   = document.getElementById('music-panel')!;
      const close   = document.getElementById('music-close')!;
      const ytSlot  = document.getElementById('yt-slot')!;
      let loaded = false;

      function openPlayer() {
        panel.classList.add('open');
        panel.setAttribute('aria-hidden', 'false');
        if (!loaded) {
          loaded = true;
          const iframe = document.createElement('iframe');
          iframe.src = 'https://www.youtube-nocookie.com/embed/m-fNVB-fAjk?autoplay=1&rel=0&modestbranding=1';
          iframe.allow = 'autoplay; encrypted-media';
          iframe.title = 'Our Song';
          ytSlot.appendChild(iframe);
        }
      }

      function closePlayer() {
        panel.classList.remove('open');
        panel.setAttribute('aria-hidden', 'true');
      }

      toggle.addEventListener('click', () => {
        panel.classList.contains('open') ? closePlayer() : openPlayer();
      });
      close.addEventListener('click', closePlayer);
    </script>

    <script>
      // Scroll reveal
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      // Chapter dot activation
      const sectionIds = ['hero', 'bento', 'message', 'gallery', 'wishes'];
      const dots = document.querySelectorAll<HTMLElement>('.chapter-dot');

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              dots.forEach((dot) => {
                dot.classList.toggle('active', dot.dataset.section === id);
              });
            }
          });
        },
        { threshold: 0.35 }
      );

      sectionIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });
    </script>
  </body>
</html>
